# Environment variables for Docker Compose
# Copy this file to .env and adjust values as needed

# Security
JWT_SECRET=change-me

# Databases (Neon or other Postgres URLs)
NEON_LUNACORE_URL=postgres://user:pass@host:5432/lunacore
NEON_LUNAPAY_URL=postgres://user:pass@host:5432/lunapay
NEON_TOTEMAPI_URL=postgres://user:pass@host:5432/totemapi

# Internal service URLs (inside Docker network)
LUNACORE_URL=http://lunacore:8080
LUNAPAY_URL=http://lunapay:8082
TOTEMAPI_URL=http://totemapi:8081

# Public URLs (browser)
NEXT_PUBLIC_LUNACORE_URL=http://localhost:8080
NEXT_PUBLIC_LUNAPAY_URL=http://localhost:8082
NEXT_PUBLIC_LUNATOTEM_API_URL=http://localhost:8081

# Asaas
ASAAS_ENVIRONMENT=production
ASAAS_SANDBOX_API_KEY=
ASAAS_SANDBOX_WALLET_ID=
ASAAS_PROD_API_KEY=
ASAAS_PROD_WALLET_ID=
ASAAS_WEBHOOK_SECRET=

# SMTP / Email (optional)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=465
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Misc
PORT=8080
